# ═══════════════════════════════════════════════════════════════════════════════
# VAAMOOSE PAYMENT INTEGRATION
# Copy this file to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════════════════════

# ─── PAYAZA CONFIGURATION (Primary Provider) ──────────────────────────────────
# Get these from: https://dashboard.payaza.africa
PAYAZA_API_KEY=Payaza_YOUR_FULL_API_KEY_HERE
PAYAZA_API_SECRET_KEY=Payaza_YOUR_FULL_API_KEY_HERE
PAYAZA_TENANT_ID=vaamoose
PAYAZA_PRODUCT_ID=app
PAYAZA_WEBHOOK_SECRET=your_payaza_webhook_secret_here

# ─── PAYSTACK CONFIGURATION (Fallback Provider) ───────────────────────────────
# Get these from: https://dashboard.paystack.com
PAYSTACK_SECRET_KEY=sk_live_YOUR_PAYSTACK_SECRET_KEY
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret_here

# ─── GENERAL PAYMENT CONFIG ───────────────────────────────────────────────────
PAYMENT_CALLBACK_URL=https://api.vaamoose.com/api/payment/callback

# ─── APPLICATION URLs ────────────────────────────────────────────────────────
FRONTEND_URL=https://vaamoose.online
VITE_API_URL=https://api.vaamoose.com
APP_URL=https://api.vaamoose.com

# ─── DATABASE ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/vaamoose

# ─── EMAIL SERVICE (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
ADMIN_EMAIL=olukoladeidowu@gmail.com

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── LOGGING ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
